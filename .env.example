# Neon Database (Serverless Postgres)
# Get your connection string from https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-example.region.aws.neon.tech/neondb?sslmode=require

# PIN to protect AI-powered endpoints (leave empty to disable)
AUTH_PIN=

# Gemini API Key for the AI Division Room bridge
# Get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# NemoClaw (NVIDIA OpenClaw + OpenShell) gateway
# Default: http://localhost:3015 — the OpenClaw gateway port inside the NemoClaw sandbox
NEMOCLAW_GATEWAY_URL=http://localhost:3015
# NVIDIA API key for cloud inference (nemotron models). Get one at https://build.nvidia.com
NEMOCLAW_API_KEY=

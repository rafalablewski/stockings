# Neon Database (Serverless Postgres)
# Get your connection string from https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-example.region.aws.neon.tech/neondb?sslmode=require

# PIN to protect AI-powered endpoints (leave empty to disable)
AUTH_PIN=

# ScraperAPI key for /scraper page (https://www.scraperapi.com)
SCRAPER_API_KEY=
